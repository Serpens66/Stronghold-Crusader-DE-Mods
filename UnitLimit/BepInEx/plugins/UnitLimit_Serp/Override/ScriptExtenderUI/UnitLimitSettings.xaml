<Grid xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="clr-namespace:SHCDESE.UI;assembly=SHCDESE">
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="10">
      <Button Content="Reset to Default"
              Command="{Binding ResetToDefaultCommand}"
              HorizontalAlignment="Left"
              Margin="0,0,0,8"
              Padding="10,3"/>
      <TextBlock Text="UNIT LIMITS" Foreground="#77AAFF" FontWeight="Bold" Margin="0,0,0,4"/>
      <TextBlock Text="-1 = unlimited. Allowed range: -1 to 10000. Existing living units count against the limit."
                 Foreground="#CCCCCC" TextWrapping="Wrap" Margin="0,0,0,6"/>
      <ItemsControl ItemsSource="{Binding LimitEntries}" Margin="0,3,0,8">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Grid Margin="0,1">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="90"/>
              </Grid.ColumnDefinitions>
              <StackPanel Grid.Column="0"
                          Orientation="Horizontal"
                          ToolTip="{Binding Key}"
                          VerticalAlignment="Center"
                          Margin="0,2,8,2">
                <Image Source="{Binding IconImage}"
                       Width="18"
                       Height="18"
                       Stretch="Uniform"
                       Margin="0,0,6,0"/>
                <TextBlock Text="{Binding DisplayName}"
                           Foreground="White"
                           VerticalAlignment="Center"/>
              </StackPanel>
              <TextBox Grid.Column="1"
                       Text="{Binding LimitText, UpdateSourceTrigger=LostFocus, Mode=TwoWay}"
                       ToolTip="{Binding LimitToolTip}"
                       MaxLength="6"
                       HorizontalContentAlignment="Right"
                       Margin="3"
                       ui:KeyboardCaptureBinding.Enabled="True"/>
            </Grid>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </StackPanel>
  </ScrollViewer>
</Grid>
