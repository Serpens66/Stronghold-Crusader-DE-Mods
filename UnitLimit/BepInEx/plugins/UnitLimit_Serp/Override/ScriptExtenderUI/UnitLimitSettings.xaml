<Grid xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="clr-namespace:SHCDESE.UI;assembly=SHCDESE">
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="10">
      <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
        <Button Content="{Binding ResetToDefaultText}"
                Command="{Binding ResetToDefaultCommand}"
                HorizontalAlignment="Left"
                Padding="10,3"/>
        <CheckBox IsChecked="{Binding EnableMod, Mode=TwoWay}"
                  Content="{Binding EnableModText}"
                  Foreground="White"
                  VerticalAlignment="Center"
                  Margin="14,0,0,0"/>
      </StackPanel>
      <TextBlock Text="{Binding TitleText}" Foreground="#77AAFF" FontWeight="Bold" Margin="0,0,0,4"/>
      <TextBlock Text="{Binding HelpText}"
                 Foreground="#CCCCCC" TextWrapping="Wrap" Margin="0,0,0,6"/>
      <Grid Margin="0,3,0,8">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="260"/>
          <ColumnDefinition Width="90"/>
        </Grid.ColumnDefinitions>
        <TextBlock Grid.Column="0"
                   Text="{Binding CampfirePeasantsText}"
                   Foreground="White"
                   ToolTip="{Binding CampfirePeasantsHelpText}"
                   VerticalAlignment="Center"
                   Margin="0,2,8,2"/>
        <TextBox Grid.Column="1"
                 Text="{Binding CampfirePeasantsLimitText, UpdateSourceTrigger=LostFocus, Mode=TwoWay}"
                 ToolTip="{Binding CampfirePeasantsHelpText}"
                 MaxLength="4"
                 HorizontalContentAlignment="Right"
                 Margin="3"
                 ui:KeyboardCaptureBinding.Enabled="True"/>
      </Grid>
      <ItemsControl ItemsSource="{Binding LimitEntries}" Margin="0,3,0,8">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Grid Margin="0,1">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="90"/>
              </Grid.ColumnDefinitions>
              <StackPanel Grid.Column="0"
                          Orientation="Horizontal"
                          ToolTip="{Binding Key}"
                          VerticalAlignment="Center"
                          Margin="0,2,8,2">
                <Image Source="{Binding IconImage}"
                       Width="18"
                       Height="18"
                       Stretch="Uniform"
                       Margin="0,0,6,0"/>
                <TextBlock Text="{Binding DisplayName}"
                           Foreground="White"
                           VerticalAlignment="Center"/>
              </StackPanel>
              <TextBox Grid.Column="1"
                       Text="{Binding LimitText, UpdateSourceTrigger=LostFocus, Mode=TwoWay}"
                       ToolTip="{Binding LimitToolTip}"
                       MaxLength="6"
                       HorizontalContentAlignment="Right"
                       Margin="3"
                       ui:KeyboardCaptureBinding.Enabled="True"/>
            </Grid>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </StackPanel>
  </ScrollViewer>
</Grid>
