<?xml version="1.0" encoding="utf-8"?>
<Patch xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Operation Type="InsertBefore" XPath="//n:TextBlock[@x:Name='TroopCostsText']">
    <Content>
      <Border x:Name="UnitLimitTroopLimitInlineHost"
              Padding="6,2,6,0"
              Margin="160,-44,0,0"
              HorizontalAlignment="Left"
              VerticalAlignment="Top"
              Panel.ZIndex="2"
              Background="#77000000"
              Visibility="{Binding LimitVisibility}"
              Tag="Ignore">
        <TextBlock Text="{Binding LimitText}"
                   FontSize="16"
                   Foreground="#FFEFF3C6"
                   Tag="Ignore">
          <TextBlock.Effect>
            <DropShadowEffect ShadowDepth="2"
                              Direction="315"
                              Color="#CC000000"
                              BlurRadius="0"/>
          </TextBlock.Effect>
        </TextBlock>
      </Border>
    </Content>
  </Operation>

