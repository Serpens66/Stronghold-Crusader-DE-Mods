<Grid xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="clr-namespace:SHCDESE.UI;assembly=SHCDESE">
  <ScrollViewer VerticalScrollBarVisibility="Auto"
                HorizontalScrollBarVisibility="Auto">
    <StackPanel Margin="10">
      <TextBlock Text="{Binding TitleText}" Foreground="#77AAFF" FontWeight="Bold" Margin="0,0,0,4"/>
      <TextBlock Text="{Binding HelpText}"
                 Foreground="#CCCCCC" TextWrapping="Wrap" Margin="0,0,0,6"/>
      <Grid Margin="0,2,0,2">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="230"/>
          <ColumnDefinition Width="150"/>
          <ColumnDefinition Width="150"/>
          <ColumnDefinition Width="150"/>
          <ColumnDefinition Width="150"/>
          <ColumnDefinition Width="74"/>
        </Grid.ColumnDefinitions>
        <TextBlock Grid.Column="0" Text="{Binding UnitHeaderText}" Foreground="#CCCCCC" FontWeight="Bold" Margin="0,0,8,0"/>
        <TextBlock Grid.Column="1" Text="{Binding Slot1HeaderText}" Foreground="#CCCCCC" FontWeight="Bold" HorizontalAlignment="Left" Margin="3,0"/>
        <TextBlock Grid.Column="2" Text="{Binding Slot2HeaderText}" Foreground="#CCCCCC" FontWeight="Bold" HorizontalAlignment="Left" Margin="3,0"/>
        <TextBlock Grid.Column="3" Text="{Binding Slot3HeaderText}" Foreground="#CCCCCC" FontWeight="Bold" HorizontalAlignment="Left" Margin="3,0"/>
        <TextBlock Grid.Column="4" Text="{Binding Slot4HeaderText}" Foreground="#CCCCCC" FontWeight="Bold" HorizontalAlignment="Left" Margin="3,0"/>
        <TextBlock Grid.Column="5" Text="{Binding GoldHeaderText}" Foreground="#CCCCCC" FontWeight="Bold" HorizontalAlignment="Right" Margin="3,0"/>
      </Grid>
      <ItemsControl ItemsSource="{Binding CostEntries}" Margin="0,3,0,8">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Grid Margin="0,1">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="230"/>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="74"/>
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Column="0"
                         Text="{Binding DisplayName}"
                         ToolTip="{Binding ToolTip}"
                         Foreground="White"
                         VerticalAlignment="Center"
                         Margin="0,2,8,2"/>
              <ComboBox Grid.Column="1"
                        ItemsSource="{Binding GoodSlotOptions}"
                        SelectedItem="{Binding SelectedGood1, Mode=TwoWay}"
                        DisplayMemberPath="DisplayName"
                        IsEnabled="{Binding IsEuropeanUnit}"
                        Margin="3"/>
              <ComboBox Grid.Column="2"
                        ItemsSource="{Binding GoodSlotOptions}"
                        SelectedItem="{Binding SelectedGood2, Mode=TwoWay}"
                        DisplayMemberPath="DisplayName"
                        IsEnabled="{Binding IsEuropeanUnit}"
                        Margin="3"/>
              <ComboBox Grid.Column="3"
                        ItemsSource="{Binding GoodSlotOptions}"
                        SelectedItem="{Binding SelectedGood3, Mode=TwoWay}"
                        DisplayMemberPath="DisplayName"
                        IsEnabled="{Binding IsEuropeanUnit}"
                        Margin="3"/>
              <ComboBox Grid.Column="4"
                        ItemsSource="{Binding GoodSlot4Options}"
                        SelectedItem="{Binding SelectedGood4, Mode=TwoWay}"
                        DisplayMemberPath="DisplayName"
                        IsEnabled="{Binding IsEuropeanUnit}"
                        Margin="3"/>
              <TextBox Grid.Column="5"
                       Text="{Binding GoldText, UpdateSourceTrigger=LostFocus, Mode=TwoWay}"
                       MaxLength="4"
                       HorizontalContentAlignment="Right"
                       Margin="3"
                       ui:KeyboardCaptureBinding.Enabled="True"/>
            </Grid>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </StackPanel>
  </ScrollViewer>
</Grid>
