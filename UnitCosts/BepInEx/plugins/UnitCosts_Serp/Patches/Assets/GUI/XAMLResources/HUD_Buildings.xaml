<?xml version="1.0" encoding="utf-8"?>
<Patch xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Operation Type="Add" XPath="/n:UserControl/n:Grid">
    <Content>
      <Grid x:Name="UnitCostsNotificationOverlay"
            Width="800"
            Height="195"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            Panel.ZIndex="10000"
            IsHitTestVisible="False"
            Visibility="{Binding IsVisible, Converter={StaticResource booleanToVisibilityConverter}}">
        <TextBlock x:Name="UnitCostsNotification"
                   Text="{Binding Message}"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Top"
                   MaxWidth="520"
                   Margin="0,-48,0,0"
                   Padding="8,1"
                   Background="#55000000"
                   Foreground="#FFDDDDDD"
                   FontSize="20"
                   TextAlignment="Center"
                   TextWrapping="Wrap"
                   Tag="Ignore">
          <TextBlock.Effect>
            <DropShadowEffect
              ShadowDepth="2"
              Direction="315"
              Color="#CC000000"
              BlurRadius="0"/>
          </TextBlock.Effect>
        </TextBlock>
      </Grid>
    </Content>
  </Operation>

  <Operation Type="InsertBefore" XPath="//n:TextBlock[@x:Name='TroopCostsText']">
    <Content>
      <Border x:Name="UnitCostsTroopCostsInlineHost"
              Padding="10,2,2,2"
              Margin="10,-44,0,0"
              HorizontalAlignment="Left"
              VerticalAlignment="Top"
              Panel.ZIndex="1"
              Background="#77000000"
              Visibility="{Binding CostsVisibility}"
              Tag="Ignore">
        <ItemsControl ItemsSource="{Binding Costs}"
                      Tag="Ignore">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <StackPanel Orientation="Horizontal"/>
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <StackPanel Orientation="Horizontal"
                          VerticalAlignment="Center">
                <TextBlock Text="{Binding Amount}"
                           FontSize="16"
                           Foreground="#FFDDDDDD"
                           Tag="Ignore">
                  <TextBlock.Effect>
                    <DropShadowEffect ShadowDepth="2"
                                      Direction="315"
                                      Color="#CC000000"
                                      BlurRadius="0"/>
                  </TextBlock.Effect>
                </TextBlock>
                <Image Source="{Binding Image}"
                       Height="18"
                       Margin="5,5,6,-5"/>
                <TextBlock Text="{Binding AmountAvailable}"
                           FontSize="16"
                           Foreground="#FFDDDDDD"
                           Tag="Ignore">
                  <TextBlock.Effect>
                    <DropShadowEffect ShadowDepth="2"
                                      Direction="315"
                                      Color="#CC000000"
                                      BlurRadius="0"/>
                  </TextBlock.Effect>
                </TextBlock>
              </StackPanel>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </Border>
    </Content>
  </Operation>

