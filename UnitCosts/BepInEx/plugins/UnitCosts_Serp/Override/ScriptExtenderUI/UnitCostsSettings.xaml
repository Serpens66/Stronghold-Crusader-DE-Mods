<Grid xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="clr-namespace:SHCDESE.UI;assembly=SHCDESE">
  <Grid.Resources>
    <BooleanToVisibilityConverter x:Key="booleanToVisibilityConverter"/>
    <DataTemplate x:Key="GoodOptionTemplate">
      <StackPanel Orientation="Horizontal">
        <Image Source="{Binding IconImage}"
               Width="16"
               Height="16"
               Stretch="Uniform"
               Margin="0,0,5,0"/>
        <TextBlock Text="{Binding DisplayName}"
                   VerticalAlignment="Center"/>
      </StackPanel>
    </DataTemplate>
  </Grid.Resources>
  <ScrollViewer VerticalScrollBarVisibility="Auto"
                HorizontalScrollBarVisibility="Auto">
    <StackPanel Margin="10">
      <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
        <Button Content="{Binding ResetToDefaultText}"
                Command="{Binding ResetToDefaultCommand}"
                HorizontalAlignment="Left"
                Padding="10,3"/>
        <CheckBox IsChecked="{Binding EnableMod, Mode=TwoWay}"
                  Content="{Binding EnableModText}"
                  Foreground="White"
                  VerticalAlignment="Center"
                  Margin="14,0,0,0"/>
      </StackPanel>
      <TextBlock Text="{Binding TitleText}" Foreground="#77AAFF" FontWeight="Bold" Margin="0,0,0,4"/>
      <TextBlock Text="{Binding HelpText}"
                 Foreground="#CCCCCC" TextWrapping="Wrap" Margin="0,0,0,6"/>
      <Grid Margin="0,2,0,2">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="230"/>
          <ColumnDefinition Width="74"/>
          <ColumnDefinition Width="150"/>
          <ColumnDefinition Width="150"/>
          <ColumnDefinition Width="150"/>
          <ColumnDefinition Width="150"/>
        </Grid.ColumnDefinitions>
        <TextBlock Grid.Column="0" Text="{Binding UnitHeaderText}" Foreground="#CCCCCC" FontWeight="Bold" Margin="0,0,8,0"/>
        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="3,0">
          <Image Source="{Binding GoldHeaderIcon}"
                 Width="18"
                 Height="18"
                 Stretch="Uniform"
                 Margin="0,0,4,0"/>
          <TextBlock Text="{Binding GoldHeaderText}" Foreground="#CCCCCC" FontWeight="Bold"/>
        </StackPanel>
        <TextBlock Grid.Column="2" Text="{Binding Slot1HeaderText}" Foreground="#CCCCCC" FontWeight="Bold" HorizontalAlignment="Left" Margin="3,0"/>
        <TextBlock Grid.Column="3" Text="{Binding Slot2HeaderText}" Foreground="#CCCCCC" FontWeight="Bold" HorizontalAlignment="Left" Margin="3,0"/>
        <TextBlock Grid.Column="4" Text="{Binding Slot3HeaderText}" Foreground="#CCCCCC" FontWeight="Bold" HorizontalAlignment="Left" Margin="3,0"/>
        <TextBlock Grid.Column="5" Text="{Binding Slot4HeaderText}" Foreground="#CCCCCC" FontWeight="Bold" HorizontalAlignment="Left" Margin="3,0"/>
      </Grid>
      <ItemsControl ItemsSource="{Binding CostEntries}" Margin="0,3,0,8">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Grid Margin="0,1">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="230"/>
                <ColumnDefinition Width="74"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <StackPanel Grid.Column="0"
                          Orientation="Horizontal"
                          ToolTip="{Binding ToolTip}"
                          VerticalAlignment="Center"
                          Margin="0,2,8,2">
                <Image Source="{Binding IconImage}"
                       Width="18"
                       Height="18"
                       Stretch="Uniform"
                       Margin="0,0,6,0"/>
                <TextBlock Text="{Binding DisplayName}"
                           Foreground="White"
                           VerticalAlignment="Center"/>
              </StackPanel>
              <TextBox Grid.Column="1"
                       Text="{Binding GoldText, UpdateSourceTrigger=LostFocus, Mode=TwoWay}"
                       ToolTip="{Binding GoldToolTip}"
                       MaxLength="4"
                       HorizontalContentAlignment="Right"
                       Margin="3"
                       ui:KeyboardCaptureBinding.Enabled="True"/>
              <StackPanel Grid.Column="2"
                          Orientation="Horizontal"
                          Visibility="{Binding IsEuropeanUnit, Converter={StaticResource booleanToVisibilityConverter}}">
                <ComboBox ItemsSource="{Binding GoodSlotOptions}"
                          SelectedItem="{Binding SelectedGood1, Mode=TwoWay}"
                          ItemTemplate="{StaticResource GoodOptionTemplate}"
                          ToolTip="{Binding Slot1ToolTip}"
                          Width="150"
                          Margin="3"/>
                <ComboBox ItemsSource="{Binding GoodSlotOptions}"
                          SelectedItem="{Binding SelectedGood2, Mode=TwoWay}"
                          ItemTemplate="{StaticResource GoodOptionTemplate}"
                          ToolTip="{Binding Slot2ToolTip}"
                          Width="150"
                          Margin="3"/>
                <ComboBox ItemsSource="{Binding GoodSlotOptions}"
                          SelectedItem="{Binding SelectedGood3, Mode=TwoWay}"
                          ItemTemplate="{StaticResource GoodOptionTemplate}"
                          ToolTip="{Binding Slot3ToolTip}"
                          Width="150"
                          Margin="3"/>
                <ComboBox ItemsSource="{Binding GoodSlot4Options}"
                          SelectedItem="{Binding SelectedGood4, Mode=TwoWay}"
                          ItemTemplate="{StaticResource GoodOptionTemplate}"
                          ToolTip="{Binding Slot4ToolTip}"
                          Width="150"
                          Margin="3"/>
              </StackPanel>
            </Grid>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <Separator Margin="0,8,0,8" Background="#44FFFFFF"/>
      <TextBlock Text="{Binding ExtraTitleText}" Foreground="#77AAFF" FontWeight="Bold" Margin="0,0,0,4"/>
      <TextBlock Text="{Binding ExtraHelpText}"
                 Foreground="#CCCCCC" TextWrapping="Wrap" Margin="0,0,0,6"/>
      <StackPanel Orientation="Horizontal" Margin="0,2,0,2">
        <TextBlock Text="{Binding UnitHeaderText}"
                   Width="230"
                   Foreground="#CCCCCC"
                   FontWeight="Bold"
                   Margin="0,0,8,0"/>
        <ItemsControl ItemsSource="{Binding ExtraCostHeaders}">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <StackPanel Orientation="Horizontal"/>
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <StackPanel Width="74"
                          Margin="3,0">
                <Image Source="{Binding IconImage}"
                       Width="18"
                       Height="18"
                       Stretch="Uniform"
                       HorizontalAlignment="Right"
                       Margin="0,0,0,1"/>
                <TextBlock Text="{Binding DisplayName}"
                           Foreground="#CCCCCC"
                           FontWeight="Bold"
                           TextAlignment="Right"/>
              </StackPanel>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </StackPanel>
      <ItemsControl ItemsSource="{Binding ExtraCostEntries}" Margin="0,3,0,8">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <StackPanel Orientation="Horizontal" Margin="0,1">
              <StackPanel Orientation="Horizontal"
                          ToolTip="{Binding ToolTip}"
                          Width="230"
                          VerticalAlignment="Center"
                          Margin="0,2,8,2">
                <Image Source="{Binding IconImage}"
                       Width="18"
                       Height="18"
                       Stretch="Uniform"
                       Margin="0,0,6,0"/>
                <TextBlock Text="{Binding DisplayName}"
                           Foreground="White"
                           VerticalAlignment="Center"/>
              </StackPanel>
              <ItemsControl ItemsSource="{Binding CostCells}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal"/>
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <TextBox Text="{Binding AmountText, UpdateSourceTrigger=LostFocus, Mode=TwoWay}"
                             ToolTip="{Binding ToolTip}"
                             MaxLength="4"
                             Width="74"
                             HorizontalContentAlignment="Right"
                             Margin="3"
                             ui:KeyboardCaptureBinding.Enabled="True"/>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </StackPanel>
  </ScrollViewer>
</Grid>
