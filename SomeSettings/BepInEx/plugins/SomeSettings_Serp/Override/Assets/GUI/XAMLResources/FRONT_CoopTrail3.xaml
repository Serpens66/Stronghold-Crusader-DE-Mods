                <DiscreteObjectKeyFrame KeyTime="0:0:0.78" Value="{StaticResource skirmish_trail_icons-29}" />
                <DiscreteObjectKeyFrame KeyTime="0:0:0.84" Value="{StaticResource skirmish_trail_icons-30}" />
                <DiscreteObjectKeyFrame KeyTime="0:0:0.90" Value="{StaticResource skirmish_trail_icons-31}" />
            </ObjectAnimationUsingKeyFrames>
        </Storyboard>
    </UserControl.Resources>

    <UserControl.Triggers>
        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
            <BeginStoryboard Storyboard="{StaticResource FlagAnim}" />
        </EventTrigger>
