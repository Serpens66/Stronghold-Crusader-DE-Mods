                        local:PropEx.TextRight=""
                        Command="{Binding MultiplayerMenuCommand}"
                        CommandParameter="CloseCoopOptions"
                        MouseEnter="CommonRedButtonEnter"
                        Style="{StaticResource BTN_SH_GlowS}" />

                </Grid>
            </Viewbox>
        </Grid>

