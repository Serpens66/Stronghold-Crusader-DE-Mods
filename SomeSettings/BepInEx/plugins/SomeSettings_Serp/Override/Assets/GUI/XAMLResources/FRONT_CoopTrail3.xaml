                            Width="208"
                            Margin="26,24,5,5"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Bottom">
                            <Slider
                                Name="MP_Settings_GameSpeed_Slider"
                                IsSnapToTickEnabled="False"
                                Minimum="2"
                                Maximum="16"
                                TickFrequency="1"
                                TickPlacement="BottomRight"
                                Style="{StaticResource SDR_SH_Plain}" />
                        </StackPanel>
                    </Grid>
                    
