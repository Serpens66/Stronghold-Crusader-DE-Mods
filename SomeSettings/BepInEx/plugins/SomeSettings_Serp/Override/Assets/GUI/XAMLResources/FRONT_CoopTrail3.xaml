                        local:PropEx.Sprite1Height="29"
                        local:PropEx.Sprite1Margin="320,0,0,0"
                        Command="{Binding MultiplayerMenuCommand}"
                        CommandParameter="Settings_ExtremePowerLord"
                        MouseEnter="CommonRedButtonEnter"
                        Style="{StaticResource BTN_SH_GlowSImage}">
                    </Button>

                    <!-- Game speed -->
                    <Grid
                        Width="350"
                        Height="60"
                        Margin="0,95,0,0"
                        Background="{StaticResource Brush.InsetColour2}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top">
                        <b:Interaction.Triggers>
                            <b:EventTrigger
                                EventName="MouseEnter">
                                <b:InvokeCommandAction
                                    Command="{Binding MultiplayerMenuCommand}"
                                    CommandParameter="Settings_GameSpeed_Enter" />
                            </b:EventTrigger>
                            <b:EventTrigger
                                EventName="MouseLeave">
                                <b:InvokeCommandAction
                                    Command="{Binding MultiplayerMenuCommand}"
                                    CommandParameter="Settings_leave" />
                            </b:EventTrigger>
                        </b:Interaction.Triggers>
                        <TextBlock
                            Width="200"
                            Margin="5,5,0,0"
                            FontSize="20"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Text="{Binding Source={x:Static local:Translate.Instance}, Path=GameTexts[TEXT_XPLAY_WAITING_ROOM_083]}" />

                        <TextBlock
                            Width="200"
                            FontSize="20"
                            Margin="0,5,9,0"
                            TextAlignment="Right"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Text="{Binding MP_Settings_GameSpeed}" />

