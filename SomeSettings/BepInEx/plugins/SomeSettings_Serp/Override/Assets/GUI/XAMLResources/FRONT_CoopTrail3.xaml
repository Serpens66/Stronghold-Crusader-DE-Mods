            x:Key="FlagAnim"
            RepeatBehavior="Forever"
            Duration="0:0:0.96">
            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="Flag" Storyboard.TargetProperty="Source">
                <DiscreteObjectKeyFrame KeyTime="0:0:0.00" Value="{StaticResource skirmish_trail_icons-16}" />
                <DiscreteObjectKeyFrame KeyTime="0:0:0.06" Value="{StaticResource skirmish_trail_icons-17}" />
                <DiscreteObjectKeyFrame KeyTime="0:0:0.12" Value="{StaticResource skirmish_trail_icons-18}" />
                <DiscreteObjectKeyFrame KeyTime="0:0:0.18" Value="{StaticResource skirmish_trail_icons-19}" />
                <DiscreteObjectKeyFrame KeyTime="0:0:0.24" Value="{StaticResource skirmish_trail_icons-20}" />
                <DiscreteObjectKeyFrame KeyTime="0:0:0.30" Value="{StaticResource skirmish_trail_icons-21}" />
                <DiscreteObjectKeyFrame KeyTime="0:0:0.36" Value="{StaticResource skirmish_trail_icons-22}" />
                <DiscreteObjectKeyFrame KeyTime="0:0:0.42" Value="{StaticResource skirmish_trail_icons-23}" />
                <DiscreteObjectKeyFrame KeyTime="0:0:0.48" Value="{StaticResource skirmish_trail_icons-24}" />
                <DiscreteObjectKeyFrame KeyTime="0:0:0.54" Value="{StaticResource skirmish_trail_icons-25}" />
                <DiscreteObjectKeyFrame KeyTime="0:0:0.60" Value="{StaticResource skirmish_trail_icons-26}" />
                <DiscreteObjectKeyFrame KeyTime="0:0:0.66" Value="{StaticResource skirmish_trail_icons-27}" />
