<Grid xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="clr-namespace:SHCDESE.UI;assembly=SHCDESE">
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="10">
      <Button Content="Reset to Default"
              Command="{Binding ResetToDefaultCommand}"
              HorizontalAlignment="Left"
              Margin="0,0,0,8"
              Padding="10,3"/>
      <TextBlock Text="BULLDOZE" Foreground="#77AAFF" FontWeight="Bold" Margin="0,0,0,4"/>
      <TextBlock Text="-1 = unchanged. Refund values are percentages from 0 to 100."
                 Foreground="#CCCCCC" TextWrapping="Wrap" Margin="0,0,0,8"/>

      <Grid Margin="0,0,0,8">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="170"/>
          <ColumnDefinition Width="90"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="Wood refund %" Foreground="White" VerticalAlignment="Center" Margin="0,3,8,3" ToolTip="Vanilla value: 50%."/>
        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding WoodRefundPercentText, UpdateSourceTrigger=LostFocus, Mode=TwoWay}" MaxLength="4" HorizontalContentAlignment="Right" Margin="3" ToolTip="Vanilla value: 50%." ui:KeyboardCaptureBinding.Enabled="True"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Stone refund %" Foreground="White" VerticalAlignment="Center" Margin="0,3,8,3" ToolTip="Vanilla value: 50%."/>
        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding StoneRefundPercentText, UpdateSourceTrigger=LostFocus, Mode=TwoWay}" MaxLength="4" HorizontalContentAlignment="Right" Margin="3" ToolTip="Vanilla value: 50%." ui:KeyboardCaptureBinding.Enabled="True"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Iron refund %" Foreground="White" VerticalAlignment="Center" Margin="0,3,8,3" ToolTip="Vanilla value: 50%."/>
        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding IronRefundPercentText, UpdateSourceTrigger=LostFocus, Mode=TwoWay}" MaxLength="4" HorizontalContentAlignment="Right" Margin="3" ToolTip="Vanilla value: 50%." ui:KeyboardCaptureBinding.Enabled="True"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Pitch refund %" Foreground="White" VerticalAlignment="Center" Margin="0,3,8,3" ToolTip="Vanilla value: 50%."/>
        <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding PitchRefundPercentText, UpdateSourceTrigger=LostFocus, Mode=TwoWay}" MaxLength="4" HorizontalContentAlignment="Right" Margin="3" ToolTip="Vanilla value: 50%." ui:KeyboardCaptureBinding.Enabled="True"/>

        <TextBlock Grid.Row="4" Grid.Column="0" Text="Gold refund %" Foreground="White" VerticalAlignment="Center" Margin="0,3,8,3" ToolTip="Vanilla value: 50%."/>
        <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding GoldRefundPercentText, UpdateSourceTrigger=LostFocus, Mode=TwoWay}" MaxLength="4" HorizontalContentAlignment="Right" Margin="3" ToolTip="Vanilla value: 50%." ui:KeyboardCaptureBinding.Enabled="True"/>
      </Grid>

      <CheckBox IsChecked="{Binding KeepStorageContent, Mode=TwoWay}"
                Content="Keep Storage Content"
                Foreground="White"
                ToolTip="When enabled, bulldozing a granary, armory, or stockpile keeps the goods stored inside by adding them back as incoming goods."
                Margin="0,4,14,4"/>

      <Separator Background="#444466" Margin="0,10"/>
      <TextBlock Text="Economy Buffs" Foreground="#77AAFF" FontWeight="Bold" Margin="0,0,0,8"/>

      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="220"/>
          <ColumnDefinition Width="90"/>
          <ColumnDefinition Width="90"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="1" Text="AI" Foreground="White" FontWeight="Bold"/>
        <TextBlock Grid.Row="0" Grid.Column="2" Text="Human" Foreground="White" FontWeight="Bold"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Multiply goods gain" Foreground="White" Margin="0,4" ToolTip="Whenever a player gains goods, he gets that amount this times on top (0 means unchanged)"/>
        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding MultiplyGoodsGainAIText, UpdateSourceTrigger=LostFocus, Mode=TwoWay}" ToolTip="Multiply goods gain / AI" Margin="3" ui:KeyboardCaptureBinding.Enabled="True"/>
        <TextBox Grid.Row="1" Grid.Column="2" Text="{Binding MultiplyGoodsGainHumanText, UpdateSourceTrigger=LostFocus, Mode=TwoWay}" ToolTip="Multiply goods gain / Human" Margin="3" ui:KeyboardCaptureBinding.Enabled="True"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Multiply goods as money" Foreground="White" Margin="0,4" ToolTip="Whenever a player gains goods, he also gets money on top as if he sold them (0 means unchanged)"/>
        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding MultiplyGoodsGainInMoneyAIText, UpdateSourceTrigger=LostFocus, Mode=TwoWay}" ToolTip="Multiply goods as money / AI" Margin="3" ui:KeyboardCaptureBinding.Enabled="True"/>
        <TextBox Grid.Row="2" Grid.Column="2" Text="{Binding MultiplyGoodsGainInMoneyHumanText, UpdateSourceTrigger=LostFocus, Mode=TwoWay}" ToolTip="Multiply goods as money / Human" Margin="3" ui:KeyboardCaptureBinding.Enabled="True"/>
      </Grid>
    </StackPanel>
  </ScrollViewer>
</Grid>
