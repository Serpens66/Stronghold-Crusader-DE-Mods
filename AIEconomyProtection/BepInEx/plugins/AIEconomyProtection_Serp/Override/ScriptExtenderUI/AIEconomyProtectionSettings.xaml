<Grid xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <StackPanel Margin="10">
    <CheckBox IsChecked="{Binding PreventAIPause, Mode=TwoWay}"
              Foreground="White"
              VerticalAlignment="Center"
              ToolTip="{Binding PreventAIPauseHelpText}"
              Margin="0,0,0,8">
      <TextBlock Text="{Binding PreventAIPauseText}" Foreground="White" TextWrapping="Wrap"/>
    </CheckBox>
    <CheckBox IsChecked="{Binding PreventEmergencyDemolition, Mode=TwoWay}"
              Foreground="White"
              VerticalAlignment="Center"
              ToolTip="{Binding PreventEmergencyDemolitionHelpText}"
              Margin="0,0,0,8">
      <TextBlock Text="{Binding PreventEmergencyDemolitionText}" Foreground="White" TextWrapping="Wrap"/>
    </CheckBox>
    <CheckBox IsChecked="{Binding PreventHovelDeletion, Mode=TwoWay}"
              Foreground="White"
              VerticalAlignment="Center"
              ToolTip="{Binding PreventHovelDeletionHelpText}"
              Margin="0,0,0,8">
      <TextBlock Text="{Binding PreventHovelDeletionText}" Foreground="White" TextWrapping="Wrap"/>
    </CheckBox>
  </StackPanel>
</Grid>
