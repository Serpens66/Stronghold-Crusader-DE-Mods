<Grid xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="clr-namespace:SHCDESE.UI;assembly=SHCDESE">
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="10">
      <TextBlock Text="START RESOURCES" Foreground="#77AAFF" FontWeight="Bold" Margin="0,0,0,8"/>

      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="220"/>
          <ColumnDefinition Width="90"/>
          <ColumnDefinition Width="90"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="1" Text="AI" Foreground="White" FontWeight="Bold"/>
        <TextBlock Grid.Row="0" Grid.Column="2" Text="Human" Foreground="White" FontWeight="Bold"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Multiply goods gain" Foreground="White" Margin="0,4"/>
        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding MultiplyGoodsGainAI, UpdateSourceTrigger=LostFocus, Mode=TwoWay}" Margin="3" ui:KeyboardCaptureBinding.Enabled="True"/>
        <TextBox Grid.Row="1" Grid.Column="2" Text="{Binding MultiplyGoodsGainHuman, UpdateSourceTrigger=LostFocus, Mode=TwoWay}" Margin="3" ui:KeyboardCaptureBinding.Enabled="True"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Multiply goods as money" Foreground="White" Margin="0,4"/>
        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding MultiplyGoodsGainInMoneyAI, UpdateSourceTrigger=LostFocus, Mode=TwoWay}" Margin="3" ui:KeyboardCaptureBinding.Enabled="True"/>
        <TextBox Grid.Row="2" Grid.Column="2" Text="{Binding MultiplyGoodsGainInMoneyHuman, UpdateSourceTrigger=LostFocus, Mode=TwoWay}" Margin="3" ui:KeyboardCaptureBinding.Enabled="True"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Set start gold (empty = skip)" Foreground="White" Margin="0,4"/>
        <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding SetStartGoldAI, UpdateSourceTrigger=LostFocus, Mode=TwoWay}" Margin="3" ui:KeyboardCaptureBinding.Enabled="True"/>
        <TextBox Grid.Row="3" Grid.Column="2" Text="{Binding SetStartGoldHuman, UpdateSourceTrigger=LostFocus, Mode=TwoWay}" Margin="3" ui:KeyboardCaptureBinding.Enabled="True"/>

        <TextBlock Grid.Row="4" Grid.Column="0" Text="Add start gold" Foreground="White" Margin="0,4"/>
        <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding AddStartGoldAI, UpdateSourceTrigger=LostFocus, Mode=TwoWay}" Margin="3" ui:KeyboardCaptureBinding.Enabled="True"/>
        <TextBox Grid.Row="4" Grid.Column="2" Text="{Binding AddStartGoldHuman, UpdateSourceTrigger=LostFocus, Mode=TwoWay}" Margin="3" ui:KeyboardCaptureBinding.Enabled="True"/>
      </Grid>

      <Separator Background="#444466" Margin="0,10"/>
      <TextBlock Text="START GOODS" Foreground="#77AAFF" FontWeight="Bold" Margin="0,0,0,8"/>
      <CheckBox IsChecked="{Binding OverwriteStartGoodsAI, Mode=TwoWay}" Content="Overwrite AI start goods" Foreground="White" Margin="0,4"/>
      <TextBox Text="{Binding StartGoodsAI, UpdateSourceTrigger=LostFocus, Mode=TwoWay}" AcceptsReturn="True" Height="160" Margin="0,3,0,8" ui:KeyboardCaptureBinding.Enabled="True"/>
      <CheckBox IsChecked="{Binding OverwriteStartGoodsHuman, Mode=TwoWay}" Content="Overwrite human start goods" Foreground="White" Margin="0,4"/>
      <TextBox Text="{Binding StartGoodsHuman, UpdateSourceTrigger=LostFocus, Mode=TwoWay}" AcceptsReturn="True" Height="160" Margin="0,3,0,8" ui:KeyboardCaptureBinding.Enabled="True"/>

      <Separator Background="#444466" Margin="0,10"/>
      <TextBlock Text="START TROOPS" Foreground="#77AAFF" FontWeight="Bold" Margin="0,0,0,8"/>
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="220"/>
          <ColumnDefinition Width="90"/>
          <ColumnDefinition Width="90"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Grid.Column="1" Text="AI" Foreground="White" FontWeight="Bold"/>
        <TextBlock Grid.Row="0" Grid.Column="2" Text="Human" Foreground="White" FontWeight="Bold"/>
        <TextBlock Grid.Row="1" Grid.Column="0" Text="Multiply start troops" Foreground="White" Margin="0,4"/>
        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding MultiplyStartTroopsAI, UpdateSourceTrigger=LostFocus, Mode=TwoWay}" Margin="3" ui:KeyboardCaptureBinding.Enabled="True"/>
        <TextBox Grid.Row="1" Grid.Column="2" Text="{Binding MultiplyStartTroopsHuman, UpdateSourceTrigger=LostFocus, Mode=TwoWay}" Margin="3" ui:KeyboardCaptureBinding.Enabled="True"/>
      </Grid>

      <TextBlock Text="Add AI troops" Foreground="White" Margin="0,8,0,0"/>
      <TextBox Text="{Binding AddStartTroopsAI, UpdateSourceTrigger=LostFocus, Mode=TwoWay}" AcceptsReturn="True" Height="160" Margin="0,3,0,8" ui:KeyboardCaptureBinding.Enabled="True"/>
      <TextBlock Text="Add human troops" Foreground="White"/>
      <TextBox Text="{Binding AddStartTroopsHuman, UpdateSourceTrigger=LostFocus, Mode=TwoWay}" AcceptsReturn="True" Height="160" Margin="0,3,0,8" ui:KeyboardCaptureBinding.Enabled="True"/>
    </StackPanel>
  </ScrollViewer>
</Grid>
