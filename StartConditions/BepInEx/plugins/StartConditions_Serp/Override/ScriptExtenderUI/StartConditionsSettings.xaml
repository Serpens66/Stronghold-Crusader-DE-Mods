<Grid xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="clr-namespace:SHCDESE.UI;assembly=SHCDESE">
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="10">
      <Button Content="Reset to Default"
              Command="{Binding ResetToDefaultCommand}"
              HorizontalAlignment="Left"
              Margin="0,0,0,8"
              Padding="10,3"/>
      <TextBlock Text="START GOLD" Foreground="#77AAFF" FontWeight="Bold" Margin="0,0,0,8"/>

      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="220"/>
          <ColumnDefinition Width="90"/>
          <ColumnDefinition Width="90"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="1" Text="AI" Foreground="White" FontWeight="Bold"/>
        <TextBlock Grid.Row="0" Grid.Column="2" Text="Human" Foreground="White" FontWeight="Bold"/>

        <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" Margin="0,4" ToolTip="Sets the initial amount of gold for each player. -1 means unchanged.">
          <Image Source="{Binding GoldIcon}" Width="18" Height="18" Stretch="Uniform" Margin="0,0,6,0"/>
          <TextBlock Text="Set start gold (-1 = unchanged)" Foreground="White" VerticalAlignment="Center"/>
        </StackPanel>
        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding SetStartGoldAIText, UpdateSourceTrigger=LostFocus, Mode=TwoWay}" ToolTip="Set start gold (-1 = unchanged) / AI" Margin="3" ui:KeyboardCaptureBinding.Enabled="True"/>
        <TextBox Grid.Row="1" Grid.Column="2" Text="{Binding SetStartGoldHumanText, UpdateSourceTrigger=LostFocus, Mode=TwoWay}" ToolTip="Set start gold (-1 = unchanged) / Human" Margin="3" ui:KeyboardCaptureBinding.Enabled="True"/>

        <StackPanel Grid.Row="2" Grid.Column="0" Orientation="Horizontal" Margin="0,4" ToolTip="Adds the specified amount of gold to the initial amount for each player.">
          <Image Source="{Binding GoldIcon}" Width="18" Height="18" Stretch="Uniform" Margin="0,0,6,0"/>
          <TextBlock Text="Add start gold" Foreground="White" VerticalAlignment="Center"/>
        </StackPanel>
        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding AddStartGoldAIText, UpdateSourceTrigger=LostFocus, Mode=TwoWay}" ToolTip="Add start gold / AI" Margin="3" ui:KeyboardCaptureBinding.Enabled="True"/>
        <TextBox Grid.Row="2" Grid.Column="2" Text="{Binding AddStartGoldHumanText, UpdateSourceTrigger=LostFocus, Mode=TwoWay}" ToolTip="Add start gold / Human" Margin="3" ui:KeyboardCaptureBinding.Enabled="True"/>
      </Grid>

      <Separator Background="#444466" Margin="0,10"/>
      <TextBlock Text="START GOODS" Foreground="#77AAFF" FontWeight="Bold" Margin="0,0,0,8"/>
      <TextBlock Text="-1 = unchanged. Allowed range: -1 to 100000." Foreground="#CCCCCC" TextWrapping="Wrap" Margin="0,0,0,6"/>
      <Grid Margin="0,0,0,4">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="220"/>
          <ColumnDefinition Width="90"/>
          <ColumnDefinition Width="90"/>
          <ColumnDefinition Width="120"/>
          <ColumnDefinition Width="90"/>
        </Grid.ColumnDefinitions>
        <TextBlock Grid.Column="1" Text="AI" Foreground="White" FontWeight="Bold"/>
        <TextBlock Grid.Column="2" Text="Human" Foreground="White" FontWeight="Bold"/>
        <TextBlock Grid.Column="3" Text="Normal/Crusade" Foreground="White" FontWeight="Bold"/>
        <TextBlock Grid.Column="4" Text="Deathmatch" Foreground="White" FontWeight="Bold"/>
      </Grid>
      <ItemsControl ItemsSource="{Binding StartGoodEntries}" Margin="0,3,0,8">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Grid Margin="0,1">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="90"/>
                <ColumnDefinition Width="90"/>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="90"/>
              </Grid.ColumnDefinitions>
              <StackPanel Grid.Column="0"
                          Orientation="Horizontal"
                          ToolTip="{Binding Key}"
                          VerticalAlignment="Center"
                          Margin="0,2,8,2">
                <Image Source="{Binding IconImage}"
                       Width="18"
                       Height="18"
                       Stretch="Uniform"
                       Margin="0,0,6,0"/>
                <TextBlock Text="{Binding DisplayName}"
                           Foreground="White"
                           VerticalAlignment="Center"/>
              </StackPanel>
              <TextBox Grid.Column="1"
                       Text="{Binding AIAmountText, UpdateSourceTrigger=LostFocus, Mode=TwoWay}"
                       ToolTip="{Binding AIAmountToolTip}"
                       MaxLength="7"
                       HorizontalContentAlignment="Right"
                       Margin="3"
                       ui:KeyboardCaptureBinding.Enabled="True"/>
              <TextBox Grid.Column="2"
                       Text="{Binding HumanAmountText, UpdateSourceTrigger=LostFocus, Mode=TwoWay}"
                       ToolTip="{Binding HumanAmountToolTip}"
                       MaxLength="7"
                       HorizontalContentAlignment="Right"
                       Margin="3"
                       ui:KeyboardCaptureBinding.Enabled="True"/>
              <TextBlock Grid.Column="3"
                         Text="{Binding NormalCrusaderAmountText}"
                         ToolTip="{Binding NormalCrusaderAmountToolTip}"
                         Foreground="#CCCCCC"
                         HorizontalAlignment="Right"
                         VerticalAlignment="Center"
                         Margin="3"/>
              <TextBlock Grid.Column="4"
                         Text="{Binding DeathmatchAmountText}"
                         ToolTip="{Binding DeathmatchAmountToolTip}"
                         Foreground="#CCCCCC"
                         HorizontalAlignment="Right"
                         VerticalAlignment="Center"
                         Margin="3"/>
            </Grid>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <Separator Background="#444466" Margin="0,10"/>
      <TextBlock Text="START TROOPS" Foreground="#77AAFF" FontWeight="Bold" Margin="0,0,0,8"/>
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="220"/>
          <ColumnDefinition Width="90"/>
          <ColumnDefinition Width="90"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Grid.Column="1" Text="AI" Foreground="White" FontWeight="Bold"/>
        <TextBlock Grid.Row="0" Grid.Column="2" Text="Human" Foreground="White" FontWeight="Bold"/>
        <TextBlock Grid.Row="1" Grid.Column="0" Text="Multiply Start Troop armies" Foreground="White" Margin="0,4" ToolTip="Start troops are updated after DelayedStartTroopCountMilliseconds, currently 20 seconds after map start. 0 = remove official start troops after the delay, 1 = unchanged, 2 = double. Allowed range: 0 to 100. CAREFUL: For AI these count as Defense-Troops, if the amount is higher than their max defense, they may not recruit new defense which may result in no ranged defense!"/>
        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding MultiplyStartTroopsAIText, UpdateSourceTrigger=LostFocus, Mode=TwoWay}" ToolTip="Multiplier for Start Troop armies / AI. Applied after DelayedStartTroopCountMilliseconds, currently 20 seconds after map start. 0 = remove, 1 = unchanged, 2 = double. Allowed range: 0 to 100." Margin="3" ui:KeyboardCaptureBinding.Enabled="True"/>
        <TextBox Grid.Row="1" Grid.Column="2" Text="{Binding MultiplyStartTroopsHumanText, UpdateSourceTrigger=LostFocus, Mode=TwoWay}" ToolTip="Multiplier for Start Troop armies / Human. Applied after DelayedStartTroopCountMilliseconds, currently 20 seconds after map start. 0 = remove, 1 = unchanged, 2 = double. Allowed range: 0 to 100." Margin="3" ui:KeyboardCaptureBinding.Enabled="True"/>
      </Grid>

      <TextBlock Text="Multiplier: 0 = remove official start troops after 20 seconds, 1 = unchanged, 2 = double. Allowed range: 0 to 100." Foreground="#CCCCCC" TextWrapping="Wrap" Margin="0,8,0,6"/>
      <TextBlock Text="Extra Start Units: -1 or 0 = no extra units. Allowed range: -1 to 100000." Foreground="#CCCCCC" TextWrapping="Wrap" Margin="0,8,0,6"/>
      <Grid Margin="0,0,0,4">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="260"/>
          <ColumnDefinition Width="90"/>
          <ColumnDefinition Width="90"/>
        </Grid.ColumnDefinitions>
        <TextBlock Grid.Column="1" Text="AI" Foreground="White" FontWeight="Bold"/>
        <TextBlock Grid.Column="2" Text="Human" Foreground="White" FontWeight="Bold"/>
      </Grid>
      <ItemsControl ItemsSource="{Binding StartTroopEntries}" Margin="0,3,0,8">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Grid Margin="0,1">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="90"/>
                <ColumnDefinition Width="90"/>
              </Grid.ColumnDefinitions>
              <StackPanel Grid.Column="0"
                          Orientation="Horizontal"
                          ToolTip="{Binding Key}"
                          VerticalAlignment="Center"
                          Margin="0,2,8,2">
                <Image Source="{Binding IconImage}"
                       Width="18"
                       Height="18"
                       Stretch="Uniform"
                       Margin="0,0,6,0"/>
                <TextBlock Text="{Binding DisplayName}"
                           Foreground="White"
                           VerticalAlignment="Center"/>
              </StackPanel>
              <TextBox Grid.Column="1"
                       Text="{Binding AIAmountText, UpdateSourceTrigger=LostFocus, Mode=TwoWay}"
                       ToolTip="{Binding AIAmountToolTip}"
                       MaxLength="7"
                       HorizontalContentAlignment="Right"
                       Margin="3"
                       ui:KeyboardCaptureBinding.Enabled="True"/>
              <TextBox Grid.Column="2"
                       Text="{Binding HumanAmountText, UpdateSourceTrigger=LostFocus, Mode=TwoWay}"
                       ToolTip="{Binding HumanAmountToolTip}"
                       MaxLength="7"
                       HorizontalContentAlignment="Right"
                       Margin="3"
                       ui:KeyboardCaptureBinding.Enabled="True"/>
            </Grid>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </StackPanel>
  </ScrollViewer>
</Grid>
