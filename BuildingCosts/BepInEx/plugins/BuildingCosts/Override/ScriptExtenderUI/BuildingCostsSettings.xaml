<Grid xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="clr-namespace:SHCDESE.UI;assembly=SHCDESE">
  <ScrollViewer VerticalScrollBarVisibility="Auto"
                HorizontalScrollBarVisibility="Auto">
    <StackPanel Margin="10">
      <TextBlock Text="BUILDING COSTS" Foreground="#77AAFF" FontWeight="Bold" Margin="0,0,0,4"/>
      <TextBlock Text="-1 = unchanged. Values 0 to 1000 set the configured construction cost for that good."
                 Foreground="#CCCCCC" TextWrapping="Wrap" Margin="0,0,0,6"/>
      <Grid Margin="0,2,0,2">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="250"/>
          <ColumnDefinition Width="78"/>
          <ColumnDefinition Width="78"/>
          <ColumnDefinition Width="78"/>
          <ColumnDefinition Width="78"/>
          <ColumnDefinition Width="78"/>
          <ColumnDefinition Width="78"/>
        </Grid.ColumnDefinitions>
        <TextBlock Grid.Column="0" Text="Building" Foreground="#CCCCCC" FontWeight="Bold" Margin="0,0,8,0"/>
        <TextBlock Grid.Column="1" Text="Wood" Foreground="#CCCCCC" FontWeight="Bold" HorizontalAlignment="Right" Margin="3,0"/>
        <TextBlock Grid.Column="2" Text="Stone" Foreground="#CCCCCC" FontWeight="Bold" HorizontalAlignment="Right" Margin="3,0"/>
        <TextBlock Grid.Column="3" Text="Iron" Foreground="#CCCCCC" FontWeight="Bold" HorizontalAlignment="Right" Margin="3,0"/>
        <TextBlock Grid.Column="4" Text="Pitch" Foreground="#CCCCCC" FontWeight="Bold" HorizontalAlignment="Right" Margin="3,0"/>
        <TextBlock Grid.Column="5" Text="Gold" Foreground="#CCCCCC" FontWeight="Bold" HorizontalAlignment="Right" Margin="3,0"/>
        <TextBlock Grid.Column="6" Text="Ale" Foreground="#CCCCCC" FontWeight="Bold" HorizontalAlignment="Right" Margin="3,0"/>
      </Grid>
      <ItemsControl ItemsSource="{Binding CostEntries}" Margin="0,3,0,8">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Grid Margin="0,1">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="78"/>
                <ColumnDefinition Width="78"/>
                <ColumnDefinition Width="78"/>
                <ColumnDefinition Width="78"/>
                <ColumnDefinition Width="78"/>
                <ColumnDefinition Width="78"/>
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Column="0"
                         Text="{Binding DisplayName}"
                         ToolTip="{Binding Key}"
                         Foreground="White"
                         VerticalAlignment="Center"
                         Margin="0,2,8,2"/>
              <TextBox Grid.Column="1"
                       Text="{Binding WoodText, UpdateSourceTrigger=LostFocus, Mode=TwoWay}"
                       MaxLength="4"
                       HorizontalContentAlignment="Right"
                       Margin="3"
                       ui:KeyboardCaptureBinding.Enabled="True"/>
              <TextBox Grid.Column="2"
                       Text="{Binding StoneText, UpdateSourceTrigger=LostFocus, Mode=TwoWay}"
                       MaxLength="4"
                       HorizontalContentAlignment="Right"
                       Margin="3"
                       ui:KeyboardCaptureBinding.Enabled="True"/>
              <TextBox Grid.Column="3"
                       Text="{Binding IronText, UpdateSourceTrigger=LostFocus, Mode=TwoWay}"
                       MaxLength="4"
                       HorizontalContentAlignment="Right"
                       Margin="3"
                       ui:KeyboardCaptureBinding.Enabled="True"/>
              <TextBox Grid.Column="4"
                       Text="{Binding PitchText, UpdateSourceTrigger=LostFocus, Mode=TwoWay}"
                       MaxLength="4"
                       HorizontalContentAlignment="Right"
                       Margin="3"
                       ui:KeyboardCaptureBinding.Enabled="True"/>
              <TextBox Grid.Column="5"
                       Text="{Binding GoldText, UpdateSourceTrigger=LostFocus, Mode=TwoWay}"
                       MaxLength="4"
                       HorizontalContentAlignment="Right"
                       Margin="3"
                       ui:KeyboardCaptureBinding.Enabled="True"/>
              <TextBox Grid.Column="6"
                       Text="{Binding AleText, UpdateSourceTrigger=LostFocus, Mode=TwoWay}"
                       MaxLength="4"
                       HorizontalContentAlignment="Right"
                       Margin="3"
                       ui:KeyboardCaptureBinding.Enabled="True"/>
            </Grid>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </StackPanel>
  </ScrollViewer>
</Grid>
