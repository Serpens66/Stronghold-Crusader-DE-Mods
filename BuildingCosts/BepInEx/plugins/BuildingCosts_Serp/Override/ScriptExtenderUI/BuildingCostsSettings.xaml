<Grid xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="clr-namespace:SHCDESE.UI;assembly=SHCDESE">
  <ScrollViewer VerticalScrollBarVisibility="Auto"
                HorizontalScrollBarVisibility="Auto">
    <StackPanel Margin="10">
      <Button Content="Reset to Default"
              Command="{Binding ResetToDefaultCommand}"
              HorizontalAlignment="Left"
              Margin="0,0,0,8"
              Padding="10,3"/>
      <TextBlock Text="{Binding TitleText}" Foreground="#77AAFF" FontWeight="Bold" Margin="0,0,0,4"/>
      <TextBlock Text="{Binding HelpText}"
                 Foreground="#CCCCCC" TextWrapping="Wrap" Margin="0,0,0,6"/>
      <Grid Margin="0,2,0,2">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="250"/>
          <ColumnDefinition Width="78"/>
          <ColumnDefinition Width="78"/>
          <ColumnDefinition Width="78"/>
          <ColumnDefinition Width="78"/>
          <ColumnDefinition Width="78"/>
        </Grid.ColumnDefinitions>
        <TextBlock Grid.Column="0" Text="{Binding BuildingHeaderText}" Foreground="#CCCCCC" FontWeight="Bold" Margin="0,0,8,0"/>
        <TextBlock Grid.Column="1" Text="{Binding WoodHeaderText}" Foreground="#CCCCCC" FontWeight="Bold" HorizontalAlignment="Right" Margin="3,0"/>
        <TextBlock Grid.Column="2" Text="{Binding StoneHeaderText}" Foreground="#CCCCCC" FontWeight="Bold" HorizontalAlignment="Right" Margin="3,0"/>
        <TextBlock Grid.Column="3" Text="{Binding IronHeaderText}" Foreground="#CCCCCC" FontWeight="Bold" HorizontalAlignment="Right" Margin="3,0"/>
        <TextBlock Grid.Column="4" Text="{Binding PitchHeaderText}" Foreground="#CCCCCC" FontWeight="Bold" HorizontalAlignment="Right" Margin="3,0"/>
        <TextBlock Grid.Column="5" Text="{Binding GoldHeaderText}" Foreground="#CCCCCC" FontWeight="Bold" HorizontalAlignment="Right" Margin="3,0"/>
      </Grid>
      <ItemsControl ItemsSource="{Binding CostEntries}" Margin="0,3,0,8">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Grid Margin="0,1">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="78"/>
                <ColumnDefinition Width="78"/>
                <ColumnDefinition Width="78"/>
                <ColumnDefinition Width="78"/>
                <ColumnDefinition Width="78"/>
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Column="0"
                         Text="{Binding DisplayName}"
                         ToolTip="{Binding BuildingToolTip}"
                         Foreground="White"
                         VerticalAlignment="Center"
                         Margin="0,2,8,2"/>
              <TextBox Grid.Column="1"
                       Text="{Binding WoodText, UpdateSourceTrigger=LostFocus, Mode=TwoWay}"
                       ToolTip="{Binding WoodToolTip}"
                       MaxLength="4"
                       HorizontalContentAlignment="Right"
                       Margin="3"
                       ui:KeyboardCaptureBinding.Enabled="True"/>
              <TextBox Grid.Column="2"
                       Text="{Binding StoneText, UpdateSourceTrigger=LostFocus, Mode=TwoWay}"
                       ToolTip="{Binding StoneToolTip}"
                       MaxLength="4"
                       HorizontalContentAlignment="Right"
                       Margin="3"
                       ui:KeyboardCaptureBinding.Enabled="True"/>
              <TextBox Grid.Column="3"
                       Text="{Binding IronText, UpdateSourceTrigger=LostFocus, Mode=TwoWay}"
                       ToolTip="{Binding IronToolTip}"
                       MaxLength="4"
                       HorizontalContentAlignment="Right"
                       Margin="3"
                       ui:KeyboardCaptureBinding.Enabled="True"/>
              <TextBox Grid.Column="4"
                       Text="{Binding PitchText, UpdateSourceTrigger=LostFocus, Mode=TwoWay}"
                       ToolTip="{Binding PitchToolTip}"
                       MaxLength="4"
                       HorizontalContentAlignment="Right"
                       Margin="3"
                       ui:KeyboardCaptureBinding.Enabled="True"/>
              <TextBox Grid.Column="5"
                       Text="{Binding GoldText, UpdateSourceTrigger=LostFocus, Mode=TwoWay}"
                       ToolTip="{Binding GoldToolTip}"
                       MaxLength="4"
                       HorizontalContentAlignment="Right"
                       Margin="3"
                       ui:KeyboardCaptureBinding.Enabled="True"/>
            </Grid>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </StackPanel>
  </ScrollViewer>
</Grid>
